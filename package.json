{
  "name": "goal-chaser-server",
  "version": "1.0.0",
  "description": "Goal Chaser - Multi-user backend server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "postinstall": "node -e \"const fs=require('fs');const src='node_modules/sql.js/dist/sql-wasm.wasm';const dst='sql-wasm.wasm';if(fs.existsSync(src)&&!fs.existsSync(dst))fs.copyFileSync(src,dst);\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "sql.js": "^1.10.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5"
  }
}